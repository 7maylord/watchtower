# ==========================================================================
# Watchtower CRE Workflows - Environment Variables
# ==========================================================================
# Copy this file to .env and fill in your actual API keys
# NEVER commit .env to git - it's already in .gitignore

# ==========================================================================
# Chainlink CRE Configuration
# ==========================================================================
CRE_ETH_PRIVATE_KEY=your_sepolia_private_key_here
CRE_TARGET=staging-settings

# ==========================================================================
# External API Keys
# ==========================================================================

# Chainalysis KYT API (Compliance Screening Workflow)
# Get your API key from: https://go.chainalysis.com/chainalysis-kyt.html
CHAINALYSIS_API_KEY=your_chainalysis_api_key_here

# Google Gemini API (Portfolio Health & Rebalancing Workflows)
# Get your API key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Pinata IPFS (All Workflows - Report Storage)
# Get your keys from: https://app.pinata.cloud/keys
PINATA_API_KEY=your_pinata_api_key_here
PINATA_API_SECRET=your_pinata_api_secret_here

# ==========================================================================
# Optional: Custodian APIs (Proof of Reserve - Future Enhancement)
# ==========================================================================
# BITGO_API_KEY=your_bitgo_api_key_here
# FIREBLOCKS_API_KEY=your_fireblocks_api_key_here

# ==========================================================================
# Development Settings
# ==========================================================================
# Set to 'true' to enable detailed logging
DEBUG=false

# Set to 'true' to use mock APIs (for testing without real API keys)
USE_MOCK_APIS=false
